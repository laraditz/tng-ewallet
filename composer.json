{
    "name": "laraditz/tng-ewallet",
    "description": "Laravel SDK for Touch 'n Go's Mini Program OpenAPI (Cashier Payment, Agreement Payment, refunds, user info, and messaging).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "tng",
        "touch n go",
        "ewallet",
        "payment"
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Laraditz\\TngEwallet\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laraditz\\TngEwallet\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laraditz\\TngEwallet\\TngEwalletServiceProvider"
            ],
            "aliases": {
                "Tng": "Laraditz\\TngEwallet\\Facades\\Tng"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
